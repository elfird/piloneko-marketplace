# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# Isi dengan domain hosting kamu saat production.
# Contoh: APP_URL="https://piloneko.vercel.app"
APP_URL="MY_APP_URL"

# SESSION_SECRET: String to use for admin token generation
SESSION_SECRET="my-super-secret-cyberpunk-key"

# AES-256 Encryption Key for WhatsApp token (32 chars exactly!)
ENCRYPTION_KEY="piloneko-aes256-key-32chars-2024"

# DEFAULT ADMIN CREDENTIALS
ADMIN_EMAIL="admin@piloneko.com"
ADMIN_PASSWORD="admin123"

# MONGO_URI: MongoDB Atlas connection string
MONGO_URI="mongodb+srv://USER:PASS@cluster.mongodb.net/DB?appName=APP"

# ==========================================
# MIDTRANS CONFIGURATION
# Dapatkan key dari: https://dashboard.midtrans.com
# ==========================================
MIDTRANS_SERVER_KEY="SB-Mid-server-CHANGE_ME"
MIDTRANS_CLIENT_KEY="SB-Mid-client-CHANGE_ME"
MIDTRANS_IS_PRODUCTION="false"

# Store WA Number
STORE_WA="08123456789"

# NODE_ENV — set ke "production" saat hosting
NODE_ENV="production"

# ==========================================
# SUPABASE STORAGE (untuk upload gambar)
# Daftar gratis di: https://supabase.com
# Project Settings → API → Service Role Key
# ==========================================
SUPABASE_URL="https://XXXXXXXX.supabase.co"
SUPABASE_SERVICE_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."

